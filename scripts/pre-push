#!/usr/bin/env bash
# pre-push hook — runs blog index integrity check before pushing to gh-pages
# Prevents KL#913 index drift from reaching production
# Install: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

REPO_DIR="$(cd "$(dirname "$0")/../.." && pwd)"

# Only run if blog/ has changes in this push
while read -r local_ref local_sha remote_ref remote_sha; do
    # Check if any blog files changed
    if git diff --name-only "$local_sha" "$remote_sha" 2>/dev/null | grep -q '^blog/'; then
        echo "🔍 Blog changes detected — running index integrity check..."
        if ! bash "$REPO_DIR/scripts/blog-index-integrity.sh"; then
            echo ""
            echo "⛔ PUSH BLOCKED: Blog index integrity check failed."
            echo "   Fix orphans first, then retry push."
            echo "   Run: ./scripts/blog-index-integrity.sh --fix"
            exit 1
        fi
    fi
done

exit 0
